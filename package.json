{
  "name": "super-subagents",
  "version": "1.3.2",
  "description": "MCP server for spawning and managing GitHub Copilot CLI tasks",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "copilot-mcp-server": "build/index.js"
  },
  "scripts": {
    "build": "tsc --noEmitOnError false; cp src/templates/*.mdx build/templates/",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "clean": "rm -rf build"
  },
  "keywords": [
    "mcp",
    "copilot",
    "github",
    "cli",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.21",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "unique-names-generator": "^4.7.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
